# Environment Configuration Example for CareerPilot AI Backend
# Copy this file to '.env' and populate with production / development values.

# 1. Server Configuration
PORT=5000
NODE_ENV=development

# 2. CORS Configuration
# Origin URL allowed to make cross-origin requests. Use comma-separated list or '*' in dev.
CORS_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173

# 3. Database Persistence
# Connection URI for MongoDB database (local or MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/careerpilot

# 4. AI Provider Configuration
# Active AI provider choice: 'gemini', 'openrouter', or 'auto' (default: gemini)
# 'auto': Tries OpenRouter first; automatically falls back to Gemini if OpenRouter returns 429 quota/rate limit error.
AI_PROVIDER=auto

# 5. Gemini AI Configuration (used when AI_PROVIDER=gemini or AI_PROVIDER=auto fallback)
# Required: Google Gemini AI API key obtained from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here
# Configured model candidate (fallback list auto-probing: gemini-2.5-flash, gemini-2.5-flash-lite, gemini-2.0-flash, gemini-1.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# 6. OpenRouter AI Configuration (used when AI_PROVIDER=openrouter or AI_PROVIDER=auto primary)
# Required: OpenRouter API key obtained from OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Configured OpenRouter model (default: openai/gpt-oss-20b:free)
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# 7. Request & Security Hardening
# Timeout in milliseconds for AI content generation requests (default: 15000)
REQUEST_TIMEOUT=15000
# Maximum allowable size for JSON/UrlEncoded request bodies (default: 10kb)
BODY_LIMIT=10kb

# 8. Rate Limiting Configuration
# Rate limit window duration in milliseconds (default: 900000 -> 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Maximum allowed requests per window per IP for protected API endpoints (default: 100)
RATE_LIMIT_MAX_REQUESTS=100
